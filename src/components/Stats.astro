<section class="stats" aria-label="Key numbers">
  <div class="wrap sgrid rv">
    <div class="stat"><div class="n" data-count="100" data-suffix="+">100+</div><div class="t">Systems Deployed</div></div>
    <div class="stat"><div class="n" data-count="72" data-tpl="<{0}hr">&lt;72hr</div><div class="t">Engagement to Kickoff</div></div>
    <div class="stat"><div class="n" data-count="3,21" data-tpl="{0}–{1}">3–21</div><div class="t">Day Delivery Window</div></div>
    <div class="stat"><div class="n" data-count="100" data-suffix="%">100%</div><div class="t">Code Ownership</div></div>
  </div>
</section>
