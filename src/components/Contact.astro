<section id="contact"><span class="amb" style="top:20%;left:50%;transform:translateX(-50%);width:760px;height:760px"></span>
  <div class="wrap" style="max-width:760px">
    <div class="frame rv"><b></b>
      <h2 class="h2 silver">Ready to Build. Start Here.</h2>
      <p class="lead">Describe your vision. Within 24 hours you'll have architecture, timeline, and investment — no ambiguity, no obligation.</p>
    </div>
    <form class="contactcard rv" id="projectForm">
      <div class="field"><label>Name <i>*</i></label><input type="text" name="name" required placeholder="Your name"></div>
      <div class="field"><label>Email <i>*</i></label><input type="email" name="email" required placeholder="you@company.com"></div>
      <div class="field"><label>Business Name <span style="color:#7d7371;font-variant:normal;letter-spacing:0;font-size:14px">(optional)</span></label><input type="text" name="business"></div>
      <div class="field"><label>Project Scope</label>
        <select name="scope">
          <option value="" selected>Select a scope...</option>
          <option>Foundation ($2,500 - $5,000)</option>
          <option>Professional ($7,500 - $15,000)</option>
          <option>Enterprise ($20,000+)</option>
          <option>Custom engagement — request a briefing</option>
        </select>
      </div>
      <div class="field"><label>How can we help? <i>*</i></label><textarea name="message" required placeholder="Tell us about the system you need..."></textarea></div>
      <button class="btn primary" type="submit" style="width:100%">Get Started &nbsp;→</button>
      <p class="formnote">Average response time: under 24 hours. No contracts. No hidden fees.</p>
    </form>
  </div>
</section>
